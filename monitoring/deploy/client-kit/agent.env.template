# === MAY BI GIAM SAT (may ngoai) ===
# Chay pc-monitor-client.exe TREN MAY NAY. No se chup man hinh MAY NAY va gui ve MAY CHU.
# May chu chi NHAN du lieu; khong the lay anh chi bang token neu khong co agent chay o day.

# 1) Dat dia chi MAY CHU (IP may chay monitoring-server, lenh ipconfig tren may chu):
MONITOR_BASE_URL=http://192.168.1.100:8010
# Hoac viet day du (neu co dong API_URL thi bo qua MONITOR_BASE_URL):
# API_URL=http://192.168.1.100:8010/api/agent/data

# 2) File auth.token cung thu muc = cung noi dung voi auth.token tren may chu
AGENT_ID=
# SECRET_TOKEN=

# Ten hien thi tren dashboard admin (tuy chon). Agent ID van la dinh danh luu anh / DB.
# DEVICE_DISPLAY_NAME=May phong A

# Windows + pc-monitor-client.exe: lan chay dau tu dang ky Task chay khi dang nhap (khong can chay lai CAI_DAT).
REGISTER_LOGON_TASK=1

# Mat khau TUY CHON: neu co gia tri, phai nhap dung khi TAT_CLIENT / UNINSTALL / go task tu dong trong CAI_DAT.
# De trong hoac xoa dong = khong khoa. Phan biet HOA thuong.
# STOP_PASSWORD=

SCREEN_CAPTURE=1
# Chat luong anh gui server (mac dinh exe: ~1600px ngang, JPEG 72). Tang neu can net hon; giam neu loi qua lon.
# SCREEN_MAX_WIDTH=1600
# SCREEN_JPEG_QUALITY=72
# SCREEN_MAX_B64_CHARS=1600000

# Luu moi lan chup vao thu muc tuy chon (khong can SCREEN_SAVE_LOCAL). Chay CHON_THU_MUC_LUU_ANH.bat de chon.
# SCREEN_SAVE_DIR=D:\ViDu\PCMonitorScreens
# Giu toi da N file screen_*.jpg (0 = giu het). Ap dung cho thu muc SCREEN_SAVE_DIR hoac screenshots/
# SCREEN_KEEP_MAX=0
# Ghi them screen_last.jpg (ghi de) trong cung thu muc luu
# SCREEN_WRITE_LAST_FILE=0

SCREEN_SAVE_LOCAL=0
INTERVAL_SECONDS=15
COMMAND_LISTENER=0

# USB: phat hien o gan / thao (su kien gui len server). monitoring-alerter -> canh bao usb_or_removable.
DETECT_USB=1

# Danh sach exe DUOC PHEP (phay, viet thuong khi so sanh). Bat REGISTERED_PROCESS_CHECK=1 de
# gui su kien unregistered_software khi co process khac danh sach (khac ENFORCE_PROCESS_ALLOWLIST).
# Vi du ngan: ALLOWED_PROCESS_NAMES=explorer.exe,notepad.exe,teams.exe,ms-teams.exe
# REGISTERED_PROCESS_CHECK=0

# Windows: canh bao neu cua so trinh duyet (Chrome/Edge/Firefox/...) giu foreground qua lau (giay).
# 0 = tat. Vi du 300 = 5 phut, 600 = 10 phut.
# LONG_BROWSER_ALERT_SECONDS=0
# Tuy chon: chi dinh ten process trinh duyet (phay). Mac dinh bo trong = Chrome, Edge, Firefox, Brave, Opera...
# BROWSER_PROCESS_NAMES=

# Windows: gui len server danh sach ten mien tu bo dem DNS (Get-DnsClientCache) — thu dong,
# khong ket noi toi tung site. Khong phai URL day du; la gan day da phan giai, khong chac dang mo tab.
# DNS_CACHE_DOMAINS=0
# DNS_CACHE_DOMAIN_MAX=120

# Luu luong + thoi gian focus trinh duyet (khong tach tung website). Chan/gioi han that can proxy/tuong lua.
TRACK_NETWORK_IO=1
TRACK_BROWSER_FOREGROUND=1
# Canh bao (webhook alerter + events) neu tong byte gui+nhan trong MOT chu ky > nguong. 0 = tat.
# Vi du 52428800 ~ 50 MiB moi INTERVAL_SECONDS.
# NETWORK_ALERT_BYTES_PER_INTERVAL=0

# ENFORCE_PROCESS_ALLOWLIST=0
