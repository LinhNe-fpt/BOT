# Sao chep thanh server.env dat canh .exe (hoac thu muc server khi uvicorn)
# Neu bo qua BEARER_TOKEN: tao/doc auth.token cung thu muc
# .exe mac dinh PORT=8010; dev uvicorn thuong 8000
# PORT=8010
# BEARER_TOKEN=...
# Token rieng cho UI admin + /api/admin/* (bo trong = dung chung BEARER_TOKEN)
# ADMIN_TOKEN=
# Thu muc luu anh man hinh (mac dinh: captures/ canh .exe)
# CAPTURES_DIR=C:\path\to\captures
