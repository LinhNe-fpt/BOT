# PC Monitor Bot — sao chep thanh .env hoac agent.env canh bot / exe
# Ban .exe: agent.env hoac auth.token cung thu muc exe (build tao auth.token trong dist)
# Dev 2 thu muc: dat AUTH_TOKEN_PATH=c:\path\chung\auth.token cho ca server va agent
API_URL=https://localhost:8000/api/agent/data
AGENT_ID=
SECRET_TOKEN=thay_bang_token_manh
INTERVAL_SECONDS=15
REQUEST_TIMEOUT=60
SCREEN_CAPTURE=1
# 0 = chi gui anh len server (khong ghi screenshots/ tren may client). 1 = luu ban dia.
SCREEN_SAVE_LOCAL=0
SCREEN_MAX_WIDTH=960
SCREEN_JPEG_QUALITY=55
# Chi khi SCREEN_SAVE_LOCAL=1: SCREEN_KEEP_MAX 0 = giu het; >0 = chi N file moi nhat
SCREEN_KEEP_MAX=0
# Chi khi SCREEN_SAVE_LOCAL=1: ghi them screen_last.jpg (ghi de)
SCREEN_WRITE_LAST_FILE=0
MAX_RETRIES=5
RETRY_BACKOFF_BASE=2
CACHE_DIR=
# Danh sách tên process cho phép (phân tách bằng dấu phẩy) — để trống = không gửi allowlist
ALLOWED_PROCESS_NAMES=
# Chặn/kill process không nằm trong allowlist (1 = bật, cần quyền admin trên Windows)
ENFORCE_PROCESS_ALLOWLIST=0
# USB: báo trong payload khi có ổ removable mới
DETECT_USB=1
# Lắng nghe lệnh từ server (chỉ bind localhost) — 0 = tắt
COMMAND_LISTENER=0
COMMAND_LISTENER_PORT=18765
COMMAND_SECRET=
