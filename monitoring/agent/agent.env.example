# Sao chep thanh agent.env dat canh pc-monitor-client.exe (build: deploy\build_apps.ps1 -Agent)
# Neu bo qua SECRET_TOKEN: doc auth.token cung thu muc (build_apps tao san trong dist)
# SECRET_TOKEN=...
# Bot .exe: bo qua dong duoi de dung mac dinh :8010; hoac dat ro:
# API_URL=http://127.0.0.1:8010/api/agent/data
# Dev (python bot.py) thuong :8000:
# API_URL=http://127.0.0.1:8000/api/agent/data
# Anh mac dinh chi gui server, khong luu dia: SCREEN_SAVE_LOCAL=0 (bo qua = mac dinh)
